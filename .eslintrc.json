{
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": "off",
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn"],
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["playwright.config.js"],
      "parserOptions": {
        "sourceType": "module"
      }
    },
    {
      "files": ["public/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      }
    }
  ]
}
